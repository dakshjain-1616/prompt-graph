# ── Prompt-Graph environment variables ──────────────────────────────────────
# Copy this file to .env and adjust as needed.
# None of these are required — sensible defaults are built in.

# Output directory for generated SVG files
OUTPUT_DIR=outputs

# SVG canvas dimensions (pixels)
SVG_WIDTH=1200
SVG_HEIGHT=800

# Node radius in pixels
NODE_RADIUS=40

# Font family used for all SVG text
FONT_FAMILY=monospace

# Node fill colours
COLOR_QUERY=#7B61FF       # Query/root node
COLOR_CHUNK=#00B4D8       # Default chunk node (score colours take precedence)
COLOR_SECONDARY=#48CAE4   # Secondary chunk nodes

# Edge colours
COLOR_EDGE=#ADB5BD        # Low-weight edge
COLOR_EDGE_STRONG=#6C757D # High-weight edge (weight >= 0.7)

# Background and text
COLOR_BG=#0D1117
COLOR_TEXT=#E6EDF3

# Score-based node colours (applied based on retrieval score)
COLOR_SCORE_HIGH=#3FB950  # score >= SCORE_HIGH_THRESHOLD
COLOR_SCORE_MED=#D29922   # score between SCORE_MED_THRESHOLD and SCORE_HIGH_THRESHOLD
COLOR_SCORE_LOW=#F85149   # score < SCORE_MED_THRESHOLD

# Score thresholds — tune these to match your retrieval model's scoring range
SCORE_HIGH_THRESHOLD=0.75
SCORE_MED_THRESHOLD=0.50

# Graph layout algorithm: spring | kamada_kawai | circular | shell
LAYOUT_ALGO=spring

# Random seed for reproducible spring layouts
LAYOUT_SEED=42

# GitHub repository URL embedded in SVG footers
GITHUB_REPO=github.com/dakshjain-1616/prompt-graph
